graph TB
    subgraph Parsing["Parsing Layer"]
        Parser["Parser<br/>(Sourceror, Elixir)"]
        TreeSitter["TreeSitterParser<br/>(Rustler NIF)"]
        CodeSchema["CodeSchema<br/>(entity struct)"]
        JSExt["JavaScriptExtractor"]
        PyExt["PythonExtractor"]
        GenExt["GenericExtractor<br/>(+ import extraction)"]
        RelExt["RelationshipExtractor"]
    end

    subgraph Indexing["Indexing Layer"]
        Indexer["Indexer<br/>(concurrent guard,<br/>async graph rebuild)"]
        Pipeline["IndexingPipeline<br/>(Broadway + telemetry)"]
        Producer["IndexingProducer<br/>(GenStage, error returns)"]
        Helpers["IndexingHelpers<br/>(file processing)"]
        Chunker["Chunker<br/>(semantic chunks)"]
        DirtyTracker["DirtyTracker<br/>(SHA256, polyglot exts)"]
        FileWatcher["FileWatcher<br/>(filesystem events)"]
    end

    subgraph Embedding["Embedding & Storage"]
        EmbModel["EmbeddingModel<br/>(Ollama HTTP client)"]
        TFIDFEmb["TFIDFEmbedder<br/>(ETS IDF, concurrent reads)"]
        QdrantClient["QdrantClient<br/>(30s timeouts, safe JSON)"]
        ChunkCache["ChunkCache (ETS)"]
        GraphCache["GraphCache (ETS)<br/>(safe delete)"]
        CacheOwner["CacheOwner<br/>(ETS table owner)"]
    end

    subgraph SearchLayer["Search Layer"]
        Search["Search<br/>(hybrid + telemetry)"]
        RelGraph["RelationshipGraph<br/>(name-indexed)"]
        GraphBoost["GraphBoost<br/>(re-ranking)"]
        Queries["Search.Queries<br/>(reverse call index)"]
    end

    subgraph Web["Web & API Layer"]
        MCPServer["MCPServer<br/>(safe JSON, deduped)"]
        Router["Router"]
        SearchCtrl["SearchController"]
        SearchLive["SearchLive<br/>(LiveView)"]
        Dashboard["DashboardLive<br/>(auto-sync Qdrant)"]
        VectorLive["VectorLive"]
        ProjectSwitcher["ProjectSwitcher<br/>(reload_from_qdrant)"]
    end

    subgraph App["Application"]
        Supervisor["Application<br/>(rest_for_one)"]
        Registry["Registry<br/>(PID lookup)"]
    end

    %% Parsing flow
    Parser -->|Elixir AST| CodeSchema
    TreeSitter -->|polyglot AST| JSExt
    TreeSitter --> PyExt
    TreeSitter --> GenExt
    JSExt --> CodeSchema
    PyExt --> CodeSchema
    GenExt --> CodeSchema
    RelExt -->|enriches| CodeSchema

    %% Indexing flow
    FileWatcher -->|events| DirtyTracker
    DirtyTracker -->|dirty files| Indexer
    Indexer -->|dispatches| Pipeline
    Pipeline -->|uses| Producer
    Pipeline -->|uses| Helpers
    Helpers -->|uses| Parser
    Helpers -->|uses| TreeSitter
    Helpers -->|uses| Chunker

    %% Embedding flow
    Helpers -->|embeds via| EmbModel
    Helpers -->|embeds via| TFIDFEmb
    Helpers -->|stores in| QdrantClient
    Helpers -->|caches in| ChunkCache
    Helpers -->|caches in| GraphCache
    CacheOwner -.->|owns| ChunkCache
    CacheOwner -.->|owns| GraphCache

    %% Search flow
    Search -->|queries| QdrantClient
    Search -->|embeds query| EmbModel
    Search -->|embeds query| TFIDFEmb
    Search -->|builds| RelGraph
    RelGraph --> GraphBoost
    Queries -->|uses| ChunkCache
    Queries -->|uses| GraphCache

    %% Web flow
    MCPServer -->|calls| Search
    MCPServer -->|calls| Queries
    MCPServer -->|calls| ProjectSwitcher
    Router --> SearchCtrl
    Router --> SearchLive
    Router --> Dashboard
    Router --> VectorLive
    SearchCtrl --> Search
    SearchLive --> Search
    Dashboard -->|polls| QdrantClient
    Dashboard -->|auto-sync| ProjectSwitcher
    ProjectSwitcher --> QdrantClient
    ProjectSwitcher --> ChunkCache
    ProjectSwitcher --> GraphCache

    %% Supervision (rest_for_one)
    Supervisor -->|manages| Indexer
    %% EmbModel is stateless HTTP client, no supervision needed
    Supervisor -->|manages| TFIDFEmb
    Supervisor -->|manages| QdrantClient
    Supervisor -->|manages| FileWatcher
    Supervisor -->|manages| DirtyTracker
    Supervisor -->|manages| CacheOwner
    Registry -.->|lookups| Producer

    style Parsing fill:#e3f2fd
    style Indexing fill:#fff3e0
    style Embedding fill:#f3e5f5
    style SearchLayer fill:#fce4ec
    style Web fill:#e8f5e9
    style App fill:#e0e0e0
