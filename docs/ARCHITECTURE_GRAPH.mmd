graph TB
    subgraph Extraction["Relationship Extraction (per language)"]
        ElixirSrc["Elixir Source<br/>(.ex, .exs)"]
        JSSrc["JS/TS Source<br/>(.js, .ts, .jsx, .tsx)"]
        PySrc["Python Source<br/>(.py)"]
        OtherSrc["Go/Rust/Java<br/>(.go, .rs, .java)"]

        ElixirExt["RelationshipExtractor<br/>calls: func invocations<br/>is_a: use/import/behaviour<br/>contains: module -> functions"]
        JSExt["JavaScriptExtractor<br/>calls: call_expression, new<br/>is_a: imports, extends<br/>contains: class -> methods<br/>+ exports as visibility"]
        PyExt["PythonExtractor<br/>calls: call nodes<br/>is_a: bases, decorators, imports<br/>contains: class -> methods<br/>+ file-level module entity"]
        GenExt["GenericExtractor<br/>calls: call nodes<br/>is_a: import_declaration,<br/>use_declaration, etc.<br/>contains: nested definitions"]
    end

    subgraph GraphData["Graph Data Model (Name-Indexed)"]
        Entity["Code Entity<br/>(name, type, file, lines)"]
        NameIndex["Name Index<br/>(lowercased name -> entity_id)<br/>O(1) exact + partial match"]
        CallEdge["calls edge<br/>(A calls B)"]
        IsAEdge["is_a edge<br/>(A inherits/imports B)"]
        ContainsEdge["contains edge<br/>(A contains B)"]
        IncomingCount["incoming_count<br/>(indexed resolution)"]
    end

    subgraph Queries["Graph Queries (Search.Queries)"]
        ReverseIndex["Reverse Call Index<br/>(callee -> [callers])<br/>Built once, O(1) lookups"]
        FindCallers["find_callers<br/>Who calls entity X?"]
        FindCallees["find_callees<br/>What does X call?"]
        AnalyzeImpact["analyze_impact<br/>Transitive callers via<br/>reverse index (depth N)"]
        FindHierarchy["find_module_hierarchy<br/>Parents + children"]
        CommunityCtx["get_community_context<br/>MapSet-indexed coupling"]
    end

    subgraph Ranking["Graph-based Re-ranking"]
        SeedNodes["Seed: top 5 results<br/>(by vector score)"]
        DirectBoost["Direct seed: +0.1"]
        IncomingBoost["Incoming refs: +0.02/ref<br/>(max 0.1)"]
        CallBoost["Calls seed: +0.03/match<br/>(max 0.1)"]
        Combined["Combined score:<br/>vector_score + graph_boost"]
    end

    ElixirSrc --> ElixirExt
    JSSrc --> JSExt
    PySrc --> PyExt
    OtherSrc --> GenExt

    ElixirExt --> Entity
    JSExt --> Entity
    PyExt --> Entity
    GenExt --> Entity

    Entity --> NameIndex
    Entity --> CallEdge
    Entity --> IsAEdge
    Entity --> ContainsEdge
    NameIndex --> IncomingCount

    ReverseIndex --> AnalyzeImpact
    NameIndex --> FindCallers
    NameIndex --> FindCallees
    Entity --> FindHierarchy
    Entity --> CommunityCtx

    SeedNodes --> DirectBoost
    IncomingCount --> IncomingBoost
    CallEdge --> CallBoost
    DirectBoost --> Combined
    IncomingBoost --> Combined
    CallBoost --> Combined

    style Extraction fill:#e3f2fd
    style GraphData fill:#f3e5f5
    style Queries fill:#fff3e0
    style Ranking fill:#fce4ec
