graph TB
    subgraph Indexing["Indexing Pipeline (Broadway)"]
        FileWatcher["FileWatcher<br/>(filesystem events)"]
        DirtyTracker["DirtyTracker<br/>(SHA256, polyglot)"]
        SourcerorParser["Sourceror<br/>(.ex, .exs)"]
        TreeSitter["Tree-sitter NIF<br/>(.js, .ts, .py, .go, .rs, .java)"]
        JSExtractor["JavaScriptExtractor<br/>(imports, exports, arrow fns)"]
        PyExtractor["PythonExtractor<br/>(imports, decorators)"]
        GenExtractor["GenericExtractor<br/>(imports for Go, Rust, Java)"]
        RelExtractor["RelationshipExtractor<br/>(Elixir calls, is_a, contains)"]
        Chunker["Chunker<br/>(semantic chunks)"]
        Bumblebee["Bumblebee<br/>(384-dim dense)"]
        TFIDFEmbed["TFIDFEmbedder<br/>(ETS IDF + sparse vectors)"]
        Telemetry["Telemetry Events<br/>(file_parsed, file_error,<br/>search_query, upsert_error)"]
    end

    subgraph Storage["Storage Layer"]
        Qdrant["Qdrant Vector DB<br/>(named vectors, sparse vectors)<br/>Per-project collections<br/>Source of truth"]
        ChunkCache["ChunkCache (ETS)<br/>(chunks by file)"]
        GraphCache["GraphCache (ETS)<br/>(call graph, name-indexed)"]
        CacheOwner["CacheOwner<br/>(owns ETS tables)"]
        TFIDF_ETS["TF-IDF IDF Table (ETS)<br/>(read_concurrency: true)"]
    end

    subgraph Search["Search Pipeline"]
        HybridSearch["Hybrid Search<br/>(RRF fusion + telemetry)"]
        GraphBuild["RelationshipGraph<br/>(name-indexed build)"]
        GraphBoost["GraphBoost<br/>(re-rank by relationships)"]
        Queries["Search.Queries<br/>(reverse call index)"]
    end

    subgraph API["API Layer"]
        MCPServer["MCPServer<br/>(8 tools, safe JSON)"]
        SearchCtrl["SearchController<br/>(REST API)"]
        SearchLive["SearchLive<br/>(LiveView)"]
        Dashboard["DashboardLive<br/>(auto-syncs from Qdrant)"]
        ProjectSwitcher["ProjectSwitcher<br/>(collection switch + reload)"]
    end

    FileWatcher -->|file changes| DirtyTracker
    DirtyTracker -->|dirty files| SourcerorParser
    DirtyTracker -->|dirty files| TreeSitter

    TreeSitter -->|JS/TS AST| JSExtractor
    TreeSitter -->|Python AST| PyExtractor
    TreeSitter -->|other AST| GenExtractor
    SourcerorParser -->|Elixir AST| RelExtractor

    JSExtractor -->|entities| Chunker
    PyExtractor -->|entities| Chunker
    GenExtractor -->|entities| Chunker
    RelExtractor -->|entities| Chunker

    Chunker --> Bumblebee
    Chunker --> TFIDFEmbed
    Bumblebee -->|dense vectors| Qdrant
    TFIDFEmbed -->|dense fallback + sparse| Qdrant
    TFIDFEmbed -.->|reads IDF| TFIDF_ETS
    Chunker --> ChunkCache
    Chunker --> GraphCache
    CacheOwner -.->|owns| ChunkCache
    CacheOwner -.->|owns| GraphCache

    HybridSearch -->|query| Qdrant
    Qdrant -->|results + payloads| GraphBuild
    GraphBuild --> GraphBoost
    GraphBoost --> Queries

    MCPServer --> HybridSearch
    MCPServer --> Queries
    MCPServer --> ProjectSwitcher
    SearchCtrl --> HybridSearch
    SearchLive --> HybridSearch
    Dashboard -->|tick: compare counts| Qdrant
    Dashboard -->|auto-sync| ProjectSwitcher
    ProjectSwitcher -->|reload| Qdrant
    ProjectSwitcher -->|clear + rebuild| ChunkCache
    ProjectSwitcher -->|clear + rebuild| GraphCache

    style Indexing fill:#e1f5ff
    style Storage fill:#e8f5e9
    style Search fill:#fff3e0
    style API fill:#f3e5f5
