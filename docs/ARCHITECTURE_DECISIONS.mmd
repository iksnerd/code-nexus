graph LR
    subgraph D1["Decision 1: Embeddings"]
        D1Q["How to embed<br/>code chunks?"]
        D1A["Ollama (primary)<br/>embeddinggemma:300m (768-dim, default)<br/>OLLAMA_MODEL env var"]
        D1B["TF-IDF (fallback)<br/>+ sparse vectors"]
        D1Why["Ollama: high-quality semantic vectors<br/>via HTTP, runs on host.<br/>TF-IDF: always works + keyword matching.<br/>IDF in ETS (read_concurrency) for<br/>lock-free concurrent embeddings."]
    end

    subgraph D2["Decision 2: Vector DB"]
        D2Q["Where to store<br/>embeddings?"]
        D2A["Qdrant"]
        D2Why["Named vectors, sparse vectors,<br/>RRF fusion server-side,<br/>per-project collections,<br/>source of truth for cross-BEAM sync."]
    end

    subgraph D3["Decision 3: Parsing"]
        D3Q["How to parse<br/>multiple languages?"]
        D3A["Sourceror (Elixir)<br/>+ Tree-sitter NIF (polyglot)"]
        D3Why["Sourceror: rich Elixir metadata.<br/>Tree-sitter NIF (Rustler):<br/>JS, TS, Python, Go, Rust, Java<br/>with depth-limited AST filtering."]
    end

    subgraph D4["Decision 4: Entity Extraction"]
        D4Q["Generic or<br/>language-specific?"]
        D4A["Language-specific extractors<br/>with generic fallback"]
        D4Why["JS: import/export/arrow fn handling.<br/>Python: decorator/import extraction.<br/>Generic: import extraction for<br/>Go/Rust/Java. All feed call graph."]
    end

    subgraph D5["Decision 5: Search + Ranking"]
        D5Q["How to rank<br/>search results?"]
        D5A["Hybrid RRF<br/>+ graph re-ranking"]
        D5Why["RRF fuses dense + sparse server-side.<br/>Graph boost re-ranks by call edges.<br/>Reverse call index: O(1) impact analysis.<br/>Name-indexed graph: O(1) resolution."]
    end

    subgraph D6["Decision 6: Multi-instance"]
        D6Q["How to sync<br/>MCP + Phoenix?"]
        D6A["Qdrant as source of truth<br/>+ auto-sync on divergence"]
        D6Why["Separate BEAMs can't share ETS/PubSub.<br/>Dashboard polls Qdrant count every 3s.<br/>On divergence: clear ETS, reload from Qdrant.<br/>Within same BEAM: PubSub for instant updates."]
    end

    subgraph D7["Decision 7: Supervision"]
        D7Q["How to handle<br/>process crashes?"]
        D7A["rest_for_one strategy<br/>+ concurrent indexing guard"]
        D7Why["rest_for_one: crash cascades to dependents.<br/>Concurrent index_directory rejected<br/>to prevent state corruption.<br/>Async graph rebuild: non-blocking."]
    end

    D1Q --> D1A
    D1Q --> D1B
    D1A --> D1Why
    D1B --> D1Why

    D2Q --> D2A
    D2A --> D2Why

    D3Q --> D3A
    D3A --> D3Why

