graph LR
    subgraph Strategy["Dual Embedding Strategy"]
        direction TB
        Input["Code Chunk Text"]
        OllamaPath["Ollama Path<br/>(primary)"]
        TFIDFPath["TF-IDF Path<br/>(fallback + sparse)"]
    end

    subgraph Ollama["Ollama (Primary Dense)"]
        Model["nomic-embed-text<br/>(137M params, F16)"]
        HTTPCall["HTTP POST<br/>/api/embed<br/>(batch support)"]
        DenseVec["768-dim Dense Vector<br/>(semantic similarity)"]
    end

    subgraph TFIDF["TF-IDF (Fallback + Sparse)"]
        Tokenize["Tokenize<br/>(lowercase, clean,<br/>filter short tokens)"]
        IDFETS["IDF Table (ETS)<br/>(read_concurrency: true,<br/>concurrent reads)"]
        CalcTFIDF["Calculate TF-IDF<br/>(term freq x IDF from ETS)"]
        Normalize["L2 Normalize<br/>(unit vectors)"]
        DenseFallback["768-dim Dense Vector<br/>(deterministic fallback)"]
        SparseVec["Sparse Vector<br/>(keyword matching)"]
        VocabUpdate["GenServer<br/>(vocabulary writes only)"]
    end

    subgraph Qdrant["Qdrant Storage"]
        NamedDense["Named Vector: 'semantic'<br/>(768-dim, cosine)"]
        NamedSparse["Sparse Vector: 'keywords'<br/>(keyword index)"]
        RRF["RRF Fusion<br/>(reciprocal rank fusion)"]
        HybridResults["Hybrid Results<br/>(best of both)"]
    end

    subgraph Fallback["Fallback Logic"]
        CheckOllama{"Ollama<br/>available?"}
        UseOllama["Use Ollama dense"]
        UseTFIDF["Use TF-IDF dense"]
    end

    Input --> CheckOllama
    CheckOllama -->|yes| Model
    CheckOllama -->|no| Tokenize
    Model --> HTTPCall
    HTTPCall --> DenseVec
    DenseVec --> UseOllama

    Tokenize --> CalcTFIDF
    IDFETS -->|concurrent read| CalcTFIDF
    VocabUpdate -->|batch write| IDFETS
    CalcTFIDF --> Normalize
    Normalize --> DenseFallback
    Normalize --> SparseVec
    DenseFallback --> UseTFIDF

    Input --> Tokenize

    UseOllama --> NamedDense
    UseTFIDF --> NamedDense
    SparseVec --> NamedSparse

    NamedDense --> RRF
    NamedSparse --> RRF
    RRF --> HybridResults

    style Strategy fill:#e1f5fe
    style Ollama fill:#c8e6c9
    style TFIDF fill:#fff9c4
    style Qdrant fill:#e8f5e9
    style Fallback fill:#ffe0b2
